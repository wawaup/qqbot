# QQ 开放平台机器人凭证（q.qq.com 申请）
BOT_APPID=your_appid_here
BOT_SECRET=your_secret_here

# 目标QQ群的 openid，多个群用逗号分隔（机器人入群后从日志中获取）
# 例如：GROUP_OPENIDS=openid_群A,openid_群B
GROUP_OPENIDS=your_group_openid_here

# 商店地址
SHOP_URL=https://pay.ldxp.cn/shop/manboup

# 扫描间隔（秒）
SCAN_INTERVAL=60

# 沙盒模式（开发调试用，true=不真实发消息）
SANDBOX=false
